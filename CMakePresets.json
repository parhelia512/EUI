{
  "version": 3,
  "configurePresets": [
    {
      "name": "glfw-debug",
      "displayName": "GLFW Debug",
      "description": "Default GLFW window backend, debug build.",
      "binaryDir": "${sourceDir}/build/glfw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "EUI_WINDOW_BACKEND": "glfw",
        "EUI_RENDER_BACKEND": "auto",
        "EUI_DEPS_MODE": "auto"
      }
    },
    {
      "name": "glfw-release",
      "displayName": "GLFW Release",
      "description": "Default GLFW window backend, release build.",
      "binaryDir": "${sourceDir}/build/glfw-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "EUI_WINDOW_BACKEND": "glfw",
        "EUI_RENDER_BACKEND": "auto",
        "EUI_DEPS_MODE": "auto"
      }
    },
    {
      "name": "sdl2-debug",
      "displayName": "SDL2 Debug",
      "description": "SDL2 window backend with a system SDL2 package.",
      "binaryDir": "${sourceDir}/build/sdl2-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "EUI_WINDOW_BACKEND": "sdl2",
        "EUI_RENDER_BACKEND": "auto",
        "EUI_DEPS_MODE": "auto"
      }
    },
    {
      "name": "sdl2-release",
      "displayName": "SDL2 Release",
      "description": "SDL2 window backend with a system SDL2 package.",
      "binaryDir": "${sourceDir}/build/sdl2-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "EUI_WINDOW_BACKEND": "sdl2",
        "EUI_RENDER_BACKEND": "auto",
        "EUI_DEPS_MODE": "auto"
      }
    },
    {
      "name": "sdl2-fetch-release",
      "displayName": "SDL2 Fetch Release",
      "description": "SDL2 window backend, fetching the pinned SDL2 source during configure.",
      "binaryDir": "${sourceDir}/build/sdl2-fetch-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "EUI_WINDOW_BACKEND": "sdl2",
        "EUI_RENDER_BACKEND": "auto",
        "EUI_DEPS_MODE": "fetch"
      }
    },
    {
      "name": "vulkan-glfw-release",
      "displayName": "Vulkan GLFW Release",
      "description": "Experimental Vulkan render backend with the GLFW window backend.",
      "binaryDir": "${sourceDir}/build/vulkan-glfw-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "EUI_WINDOW_BACKEND": "glfw",
        "EUI_RENDER_BACKEND": "vulkan",
        "EUI_ENABLE_EXPERIMENTAL_VULKAN_BACKEND": "ON",
        "EUI_DEPS_MODE": "auto"
      }
    },
    {
      "name": "vulkan-sdl2-release",
      "displayName": "Vulkan SDL2 Release",
      "description": "Experimental Vulkan render backend with the SDL2 window backend.",
      "binaryDir": "${sourceDir}/build/vulkan-sdl2-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "EUI_WINDOW_BACKEND": "sdl2",
        "EUI_RENDER_BACKEND": "vulkan",
        "EUI_ENABLE_EXPERIMENTAL_VULKAN_BACKEND": "ON",
        "EUI_DEPS_MODE": "auto"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "glfw-debug",
      "configurePreset": "glfw-debug",
      "configuration": "Debug"
    },
    {
      "name": "glfw-release",
      "configurePreset": "glfw-release",
      "configuration": "Release"
    },
    {
      "name": "sdl2-debug",
      "configurePreset": "sdl2-debug",
      "configuration": "Debug"
    },
    {
      "name": "sdl2-release",
      "configurePreset": "sdl2-release",
      "configuration": "Release"
    },
    {
      "name": "sdl2-fetch-release",
      "configurePreset": "sdl2-fetch-release",
      "configuration": "Release"
    },
    {
      "name": "vulkan-glfw-release",
      "configurePreset": "vulkan-glfw-release",
      "configuration": "Release"
    },
    {
      "name": "vulkan-sdl2-release",
      "configurePreset": "vulkan-sdl2-release",
      "configuration": "Release"
    }
  ]
}
